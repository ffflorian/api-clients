{
  "author": "Florian Imdahl <git@ffflorian.de>",
  "bin": "dist/cli.js",
  "dependencies": {
    "@ffflorian/api-client": "2.5.1",
    "commander": "14.0.3"
  },
  "description": "An icanhazdadjoke.com API client with a CLI.",
  "devDependencies": {
    "@types/node": "~25",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "nock": "14.0.12",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typedoc": "0.28.19",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">= 21"
  },
  "exports": "./dist/index.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "api",
    "api-client",
    "cli",
    "icanhazdadjoke"
  ],
  "license": "GPL-3.0",
  "name": "@ffflorian/icanhazdadjoke",
  "readme": "https://github.com/ffflorian/api-clients#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ffflorian/api-clients.git"
  },
  "scripts": {
    "build": "yarn build:ts",
    "build:ts": "tsgo -p tsconfig.build.json",
    "build:docs": "typedoc --tsconfig tsconfig.build.json --options ../../typedoc.json --out ../../docs/packages/icanhazdadjoke src/index.ts",
    "clean": "rimraf dist",
    "dist": "yarn clean && yarn build",
    "start": "tsx src/cli.ts",
    "test": "vitest"
  },
  "version": "2.6.0"
}
