{
  "author": "Florian Imdahl <git@ffflorian.de>",
  "dependencies": {
    "@ffflorian/api-client": "2.5.3"
  },
  "description": "A npms.io API client",
  "devDependencies": {
    "@types/node": "~26",
    "nock": "14.0.16",
    "rimraf": "6.1.3",
    "typedoc": "0.28.20",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">= 21"
  },
  "exports": "./dist/index.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "api",
    "api-client",
    "npms.io",
    "npms",
    "npmsio"
  ],
  "license": "GPL-3.0",
  "name": "npms.io",
  "readme": "https://github.com/ffflorian/api-clients#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ffflorian/api-clients.git"
  },
  "scripts": {
    "build": "yarn build:ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:docs": "typedoc --tsconfig tsconfig.build.json --options ../../typedoc.json --out ../../docs/packages/npms.io src/index.ts",
    "clean": "rimraf dist",
    "dist": "yarn clean && yarn build",
    "test": "vitest run"
  },
  "version": "2.6.0"
}
