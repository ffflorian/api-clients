{
  "author": "Florian Imdahl <git@ffflorian.de>",
  "dependencies": {
    "@ffflorian/api-client": "2.5.1"
  },
  "description": "A corona-warn-app API client",
  "devDependencies": {
    "@types/node": "~24",
    "rimraf": "6.1.3",
    "typedoc": "0.28.19",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">= 21"
  },
  "exports": "./dist/index.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "api",
    "api-client",
    "corona-warn-app",
    "corona",
    "cwa"
  ],
  "license": "GPL-3.0",
  "name": "corona-warn-app",
  "private": true,
  "readme": "https://github.com/ffflorian/api-clients#readme",
