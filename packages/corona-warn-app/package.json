    "type": "git",
    "url": "git+https://github.com/ffflorian/api-clients.git"
  },
  "scripts": {
    "build": "yarn build:ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:docs": "typedoc --tsconfig tsconfig.build.json --options ../../typedoc.json --out ../../docs/packages/corona-warn-app src/index.ts",
    "clean": "rimraf dist",
    "dist": "yarn clean && yarn build",
    "test": "exit 0"
  },
  "version": "2.4.7"
}
